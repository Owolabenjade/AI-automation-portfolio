    {
      "parameters": {
        "jsCode": "// Format thread messages for AI context\nconst messages = $input.all();\nconst trigger = $('Slack Trigger').first().json;\n\n// Build conversation history\nlet conversationHistory = messages\n  .map(item => item.json)\n  .filter(msg => !msg.bot_id) // Exclude bot messages\n  .map(msg => msg.text.replace(/<@[A-Z0-9]+>/g, '').trim()) // Remove @mentions\n  .join('\\n\\n');\n\nreturn {\n  json: {\n    conversationHistory: conversationHistory,\n    currentMessage: trigger.text.replace(/<@[A-Z0-9]+>/g, '').trim(),\n    channel: trigger.channel,\n    thread_ts: trigger.thread_ts || trigger.ts,\n    user: trigger.user,\n    isThread: true\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        -160
      ],
      "id": "b3843f19-ac8b-42b4-b8c9-9ffe54a2cf1f",
      "name": "Format Thread Context"
    },
    {
      "parameters": {
        "jsCode": "// Format single message (no thread)\nconst trigger = $('Slack Trigger').first().json;\n\nreturn {\n  json: {\n    conversationHistory: '',\n    currentMessage: trigger.text.replace(/<@[A-Z0-9]+>/g, '').trim(),\n    channel: trigger.channel,\n    thread_ts: trigger.ts,\n    user: trigger.user,\n    isThread: false\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
